{
  "$schema": "https://turbo.build/schema.json",
  "telemetry": "disabled",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "deploy": {
      "dependsOn": ["@shortlink/web#build", "build"],
      "passThroughEnv": ["CLOUDFLARE_API_TOKEN"]
    }
  }
}
