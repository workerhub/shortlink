{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 6am on monday"],
  "timezone": "UTC",
  "automerge": false,
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "groupName": "Cloudflare packages",
      "matchPackageNames": [
        "/^@cloudflare//"
      ]
    },
    {
      "groupName": "SimpleWebAuthn packages",
      "matchPackageNames": [
        "/^@simplewebauthn//"
      ]
    },
    {
      "groupName": "TanStack packages",
      "matchPackageNames": [
        "/^@tanstack//"
      ]
    }
  ]
}
